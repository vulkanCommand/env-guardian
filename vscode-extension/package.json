{
  "name": "envguard-cli",
  "displayName": "Env Guardian",
  "description": "Validate, secure, and scan environment files from VS Code with Env Guardian CLI.",
  "version": "0.1.13",
  "publisher": "vulkanCommand",
  "icon": "assets/icon.png",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/vulkanCommand/env-guardian.git"
  },
  "bugs": {
    "url": "https://github.com/vulkanCommand/env-guardian/issues",
    "email": "gdkalyan2109@gmail.com"
  },
  "homepage": "https://github.com/vulkanCommand/env-guardian#readme",
  "engines": {
    "vscode": "^1.80.0"
  },
  "categories": [
    "Other"
  ],
  "keywords": [
    "env",
    "environment-variables",
    "dotenv",
    "security",
    "validation",
    "secrets",
    "secret-scanner",
    "devops",
    "ci"
  ],
  "galleryBanner": {
    "color": "#065f46",
    "theme": "dark"
  },
  "scripts": {
    "package": "npx @vscode/vsce package",
    "publish": "npx @vscode/vsce publish"
  },
  "activationEvents": [
    "onCommand:envGuardian.validate",
    "onCommand:envGuardian.validateAll",
    "onCommand:envGuardian.ci",
    "onCommand:envGuardian.security",
    "onCommand:envGuardian.logScan",
    "onCommand:envGuardian.version"
  ],
  "main": "./extension.js",
  "contributes": {
    "commands": [
      {
        "command": "envGuardian.validate",
        "title": "Env Guardian: Validate"
      },
      {
        "command": "envGuardian.validateAll",
        "title": "Env Guardian: Validate All Environments"
      },
      {
        "command": "envGuardian.ci",
        "title": "Env Guardian: Run CI Check"
      },
      {
        "command": "envGuardian.security",
        "title": "Env Guardian: Run Security Scan"
      },
      {
        "command": "envGuardian.logScan",
        "title": "Env Guardian: Run Log Exposure Scan"
      },
      {
        "command": "envGuardian.version",
        "title": "Env Guardian: Show Version"
      }
    ],
    "configuration": {
      "title": "Env Guardian",
      "properties": {
        "envGuardian.executablePath": {
          "type": "string",
          "default": "envguard",
          "description": "Path to the envguard executable."
        },
        "envGuardian.envFile": {
          "type": "string",
          "default": ".env",
          "description": "Target env file used by validation commands."
        },
        "envGuardian.exampleFile": {
          "type": "string",
          "default": ".env.example",
          "description": "Example env file used by validation commands."
        },
        "envGuardian.rootDirectory": {
          "type": "string",
          "default": ".",
          "description": "Root directory used by scan commands."
        },
        "envGuardian.useJson": {
          "type": "boolean",
          "default": false,
          "description": "Run supported commands with --json output."
        }
      }
    }
  }
}
